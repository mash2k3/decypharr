---
const label = Astro.locals.t('themeSelect.accessibleLabel');
---

<starlight-theme-toggle>
	<button class="theme-toggle" type="button" aria-label={label} title={label}>
		<span class="icon icon-light" aria-hidden="true">
			<svg viewBox="0 0 24 24" role="presentation">
				<path
					d="M5 12a1 1 0 0 0-1-1H3a1 1 0 0 0 0 2h1a1 1 0 0 0 1-1Zm.64 5-.71.71a1 1 0 0 0 0 1.41 1 1 0 0 0 1.41 0l.71-.71A1 1 0 0 0 5.64 17ZM12 5a1 1 0 0 0 1-1V3a1 1 0 0 0-2 0v1a1 1 0 0 0 1 1Zm5.66 2.34a1 1 0 0 0 .7-.29l.71-.71a1 1 0 1 0-1.41-1.41l-.66.71a1 1 0 0 0 0 1.41 1 1 0 0 0 .66.29Zm-12-.29a1 1 0 0 0 1.41 0 1 1 0 0 0 0-1.41l-.71-.71a1.004 1.004 0 1 0-1.43 1.41l.73.71ZM21 11h-1a1 1 0 0 0 0 2h1a1 1 0 0 0 0-2Zm-2.64 6A1 1 0 0 0 17 18.36l.71.71a1 1 0 0 0 1.41 0 1 1 0 0 0 0-1.41l-.76-.66ZM12 6.5a5.5 5.5 0 1 0 5.5 5.5A5.51 5.51 0 0 0 12 6.5Zm0 9a3.5 3.5 0 1 1 0-7 3.5 3.5 0 0 1 0 7Zm0 3.5a1 1 0 0 0-1 1v1a1 1 0 0 0 2 0v-1a1 1 0 0 0-1-1Z"
				/>
			</svg>
		</span>
		<span class="icon icon-dark" aria-hidden="true">
			<svg viewBox="0 0 24 24" role="presentation">
				<path
					d="M21.64 13a1 1 0 0 0-1.05-.14 8.049 8.049 0 0 1-3.37.73 8.15 8.15 0 0 1-8.14-8.1 8.59 8.59 0 0 1 .25-2A1 1 0 0 0 8 2.36a10.14 10.14 0 1 0 14 11.69 1 1 0 0 0-.36-1.05Zm-9.5 6.69A8.14 8.14 0 0 1 7.08 5.22v.27a10.15 10.15 0 0 0 10.14 10.14 9.784 9.784 0 0 0 2.1-.22 8.11 8.11 0 0 1-7.18 4.32v-.04Z"
				/>
			</svg>
		</span>
	</button>
</starlight-theme-toggle>

{/* Inlined to avoid FOUC. Uses global scope from `ThemeProvider.astro` */}
<script is:inline>
	StarlightThemeProvider.updatePickers();
</script>

<script>
	type Theme = 'auto' | 'dark' | 'light';

	const storageKey = 'starlight-theme';

	const parseTheme = (theme: unknown): Theme =>
		theme === 'auto' || theme === 'dark' || theme === 'light' ? theme : 'auto';

	const loadTheme = (): Theme =>
		parseTheme(typeof localStorage !== 'undefined' && localStorage.getItem(storageKey));

	function storeTheme(theme: Theme): void {
		if (typeof localStorage !== 'undefined') {
			localStorage.setItem(storageKey, theme === 'light' || theme === 'dark' ? theme : '');
		}
	}

	const getPreferredColorScheme = (): Theme =>
		matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark';

	function setTheme(theme: Theme): void {
		StarlightThemeProvider.updatePickers(theme);
		document.documentElement.dataset.theme = theme === 'auto' ? getPreferredColorScheme() : theme;
		storeTheme(theme);
	}

	function getEffectiveTheme(): Theme {
		const current = document.documentElement.dataset.theme;
		return current === 'light' || current === 'dark' ? current : getPreferredColorScheme();
	}

	matchMedia('(prefers-color-scheme: light)').addEventListener('change', () => {
		if (loadTheme() === 'auto') setTheme('auto');
	});

	class StarlightThemeToggle extends HTMLElement {
		btn = this.querySelector('button')!;

		constructor() {
			super();
			setTheme(loadTheme());
			this.btn.addEventListener('click', () => {
				const next = getEffectiveTheme() === 'light' ? 'dark' : 'light';
				setTheme(next);
			});
		}
	}

	customElements.define('starlight-theme-toggle', StarlightThemeToggle);
</script>

<style>
	@layer starlight.core {
		.theme-toggle {
			display: inline-flex;
			align-items: center;
			justify-content: center;
			width: 2.25rem;
			height: 2.25rem;
			border-radius: 999px;
			border: 1px solid var(--sl-color-gray-5);
			background: transparent;
			color: var(--sl-color-text);
			cursor: pointer;
		}

		.theme-toggle:hover {
			background: var(--sl-color-gray-6);
		}

		.theme-toggle:focus-visible {
			outline: 2px solid var(--sl-color-accent);
			outline-offset: 2px;
		}

		.icon {
			display: inline-flex;
			width: 1.1rem;
			height: 1.1rem;
		}

		.icon svg {
			width: 100%;
			height: 100%;
			fill: currentColor;
		}

		:global([data-theme='light']) .icon-dark {
			display: none;
		}

		:global([data-theme='dark']) .icon-light {
			display: none;
		}
	}
</style>
